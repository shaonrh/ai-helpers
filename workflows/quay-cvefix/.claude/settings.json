{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/session-setup.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/guard-repo-admin.sh",
            "if": "Bash(gh *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/scripts/check-embargo.sh",
            "if": "Bash(git *)",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/notify-pr-created.sh",
            "if": "Bash(*gh pr create*)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/scripts/notify-push.sh",
            "if": "Bash(*git push*)",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
